rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isEngineer() {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'engineer';
    }

    // User Profiles
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId) || isAdmin();
    }

    // Clients
    match /clients/{clientId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Landlords
    match /landlords/{landlordId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Properties
    match /properties/{propertyId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Jobs
    match /jobs/{jobId} {
      allow read: if isSignedIn();
      allow create: if isAdmin();
      allow update: if isAdmin() || (isEngineer() && resource.data.engineerId == request.auth.uid);
      allow delete: if isAdmin();
    }

    // Certificates
    match /certificates/{certificateId} {
      allow read: if true;
      allow create: if isSignedIn() || true;
      allow update: if isSignedIn() || true;
      allow delete: if isAdmin();
    }
  }
}
